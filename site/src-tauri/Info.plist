<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <!--
          Camera access is used solely to scan another device's pairing QR code
          in the sync settings.
        -->
        <key>NSCameraUsageDescription</key>
        <string>FLTS uses the camera to scan another device's pairing QR code.</string>
        <!--
          The library now lives in app-private storage (Application Support), so
          the Documents-folder file-sharing keys (UIFileSharingEnabled /
          LSSupportsOpeningDocumentsInPlace) are intentionally omitted to keep it
          invisible to the Files app.
        -->
    </dict>
</plist>
