{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:path:default",
    "core:resources:default",
    "core:webview:default",
    "core:window:default",
    "dialog:allow-open",
    "log:default",
    "os:allow-platform"
  ]
}